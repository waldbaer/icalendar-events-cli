{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: icalendar-events-cli script",
      "type": "debugpy",
      "request": "launch",
      "program": ".venv/bin/icalendar-events-cli",
      "args": ["--calendar.url", "file://${workspaceFolder}/tests/calendar_examples/GermanHolidays.ics",
                "--filter.start-date", "1970-01-01",
                "--filter.end-date", "2040-12-31",
                "--filter.summary", ".*(Weihnacht|Oster).*"
      ],
      "justMyCode": true
    },
    {
      "name": "Python Debugger: Module pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "justMyCode": true,
      "args": ["-k", "test_"]
    },
  ]
}
